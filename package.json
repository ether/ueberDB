      "name": "Peter Martischka"
    }
  ],
  "devDependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@types/async": "^3.2.25",
    "@types/mssql": "^9.1.11",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/rethinkdb": "^2.3.21",
    "@types/wtfnode": "^0.10.0",
    "async": "^3.2.6",
    "cassandra-driver": "^4.8.0",
    "cli-table3": "^0.6.5",
    "dirty-ts": "^1.1.8",
    "mongodb": "^7.1.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "mssql": "^12.2.1",
    "mysql2": "^3.22.0",
    "nano": "^11.0.5",
    "pg": "^8.20.0",
    "randexp-ts": "^1.0.5",
    "redis": "^5.11.0",
    "rethinkdb": "^2.4.2",
    "rolldown": "^1.0.0-rc.15",
    "rusty-store-kv": "^1.3.1",
    "semver": "^7.7.4",
    "simple-git": "^3.36.0",
    "surrealdb": "^2.0.3",
    "testcontainers": "^11.14.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wtfnode": "^0.10.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ether/ueberDB.git"
  },
  "main": "./dist/index.js",
  "version": "5.0.41",
  "bugs": {
    "url": "https://github.com/ether/ueberDB/issues"
  },
  "files": [
    "dist/databases",
    "dist/index.js",
    "dist/*.d.ts",
    "dist/lib",
    "dist/_virtual"
  ],
  "homepage": "https://github.com/ether/ueberDB",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "pnpm exec rolldown -c rolldown.config.mjs",
    "build:types": "pnpm exec tsc --emitDeclarationOnly",
    "test": "vitest --test-timeout=120000",
    "ts-check": "tsc --noEmit",
    "ts-check:watch": "tsc --noEmit --watch"
  },
  "_npmUser": {
    "name": "johnyma22",
    "email": "john@mclear.co.uk"
  },
  "maintainers": [
    {
      "name": "John McLear",
      "email": "john@mclear.co.uk"
    }
  ],
  "engines": {
    "node": ">=22.22.0"
  }
}
