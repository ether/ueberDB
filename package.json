    "mongodb": "^7.2.0",
    "mssql": "^12.5.5",
    "mysql2": "^3.22.5",
    "nano": "^11.0.5",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.69.0",
    "pg": "^8.21.0",
    "randexp-ts": "^1.0.5",
    "redis": "^6.0.0",
    "rethinkdb": "^2.4.2",
    "rolldown": "^1.1.0",
    "semver": "^7.8.3",
    "surrealdb": "^2.0.3",
    "testcontainers": "^12.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wtfnode": "^0.10.1"
  },
  "peerDependencies": {
    "@elastic/elasticsearch": "^9.0.0",
    "async": "^3.0.0",
    "cassandra-driver": "^4.0.0",
    "dirty-ts": "^1.0.0",
