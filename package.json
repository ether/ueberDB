{
  "name": "ueberdb2",
  "version": "6.1.8",
  "description": "Transform every database into a object key value store",
  "keywords": [
    "database",
    "keyvalue"
  ],
  "homepage": "https://github.com/ether/ueberDB",
  "bugs": {
    "url": "https://github.com/ether/ueberDB/issues"
