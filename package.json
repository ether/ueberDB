{
  "name": "ueberdb2",
  "description": "Transform every database into a object key value store",
  "url": "https://github.com/ether/ueberDB",
  "type": "commonjs",
  "types": "./dist/index.d.ts",
  "keywords": [
    "database",
    "keyvalue"
  ],
  "author": {
    "name": "The Etherpad Foundation"
  },
  "contributors": [
